{
  "apiType": "stageMode",
  "buildOption": {
    "sourceOption": {
      "workers": [
        './src/main/ets/workers/CameraWorker.ets'
      ]
    }
  },
  "buildOptionSet": [
    {
      "name": "debug",
      "debuggable": true,
      "arkOptions": {
        "obfuscation": {
          "ruleOptions": {
            "enable": false,
            "files": [
            ]
          }
        }
      }
      /*,
            "nativeLib": {
              "debugSymbol": {
                "strip": true,
                "exclude": []
              }
            }*/
    },
  ],
  "targets": [
    {
      "name": "default"
    },
    {
      "name": "ohosTest",
    }
  ]
}